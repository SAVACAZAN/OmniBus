{
  "name": "omnibus-monetization-system",
  "version": "1.0.0",
  "description": "OmniBus status token on-ramp and staking system with post-quantum cryptography",
  "main": "services/agent-on-ramp-service.js",
  "scripts": {
    "test": "hardhat test",
    "compile": "hardhat compile",
    "deploy:omnibus": "hardhat run scripts/deploy-status-tokens.js --network omnibus",
    "deploy:sepolia": "hardhat run scripts/deploy-status-tokens.js --network sepolia",
    "deploy:base-sepolia": "hardhat run scripts/deploy-status-tokens.js --network baseSepolia",
    "agent": "node services/agent-on-ramp-service.js",
    "agent:dev": "nodemon services/agent-on-ramp-service.js",
    "node:hardhat": "hardhat node",
    "gas-report": "REPORT_GAS=true hardhat test",
    "lint": "eslint .",
    "format": "prettier --write '**/*.js'",
    "verify": "hardhat verify --network omnibus",
    "docs": "solidity-docgen -i contracts -o docs"
  },
  "keywords": [
    "omnibus",
    "status-tokens",
    "usdc-onramp",
    "staking",
    "defi",
    "ethereum",
    "base",
    "post-quantum-crypto"
  ],
  "author": "OmniBus AI Team",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.7",
    "@nomicfoundation/hardhat-ethers": "^3.0.7",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.11",
    "chai": "^4.3.10",
    "ethers": "^6.13.0",
    "hardhat": "^2.22.8",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.12",
    "prettier": "^3.2.5",
    "prettier-plugin-solidity": "^1.3.1",
    "eslint": "^8.56.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "optionalDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
